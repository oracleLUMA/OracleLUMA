# Solana RPC endpoint used by the scheduler and balance poller.
# Public RPCs work for low traffic; use a paid provider for production.
RPC_URL=https://solana-rpc.publicnode.com

# Optional override exposed to the browser (Phantom flow).
# Defaults to RPC_URL above if omitted.
NEXT_PUBLIC_RPC_URL=https://solana-rpc.publicnode.com

# Admin keypair (base58-encoded secret key) — the only signer allowed
# to call write_data on the LUMA program. Keep this server-side.
ADMIN_PRIVATE=

# Secret used to sign session JWTs. Any long random string.
JWT_SECRET=

# Postgres connection — schema is auto-created on first boot.
POSTGRE_USER=luma
POSTGRE_PASS=
POSTGRE_IP=127.0.0.1
POSTGRE_PORT=5432
POSTGRE_BD=luma
